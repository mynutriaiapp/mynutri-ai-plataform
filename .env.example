# ==============================================================================
# MyNutri AI — Variáveis de Ambiente (TEMPLATE)
# ==============================================================================
# INSTRUÇÕES:
# 1. Copie: cp .env.example .env
# 2. Preencha os valores reais
# 3. NUNCA commite o arquivo .env no git (já está no .gitignore)
# 4. Em produção (Render): configure as vars no painel Environment Variables
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# Django — OBRIGATÓRIO
# ──────────────────────────────────────────────────────────────────────────────
# Gere uma chave segura:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-random-secret-key-here-min-50-chars

# True apenas em desenvolvimento local. NUNCA True em produção.
DEBUG=True

# Hosts permitidos separados por vírgula
# Desenvolvimento: localhost,127.0.0.1
# Produção (Render): seu-app.onrender.com  (o Render também injeta RENDER_EXTERNAL_HOSTNAME automaticamente)
ALLOWED_HOSTS=localhost,127.0.0.1

# ──────────────────────────────────────────────────────────────────────────────
# Banco de Dados
# ──────────────────────────────────────────────────────────────────────────────
# Desenvolvimento: deixe vazio ou use sqlite (padrão automático)
# DATABASE_URL=sqlite:///db.sqlite3

# Produção (Render): o Render injeta DATABASE_URL automaticamente via render.yaml
# Formato PostgreSQL: postgres://user:password@host:5432/dbname
# DATABASE_URL=postgres://mynutri:senha@host:5432/mynutri

# ──────────────────────────────────────────────────────────────────────────────
# CORS — origens permitidas para o frontend (produção apenas)
# ──────────────────────────────────────────────────────────────────────────────
# Separe múltiplas origens por vírgula (sem espaços)
# Desenvolvimento: não precisa (DEBUG=True libera tudo automaticamente)
# Produção: URL do seu frontend hospedado
# CORS_ALLOWED_ORIGINS=https://meusite.com,https://www.meusite.com

# ──────────────────────────────────────────────────────────────────────────────
# API de Inteligência Artificial — OBRIGATÓRIO
# ──────────────────────────────────────────────────────────────────────────────
# Gere em: https://platform.openai.com/api-keys
# ⚠️  Use uma chave dedicada para este projeto com limite de uso/quota definido
AI_API_KEY=sk-proj-your-api-key-here
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-3.5-turbo

# ──────────────────────────────────────────────────────────────────────────────
# Cache (opcional)
# ──────────────────────────────────────────────────────────────────────────────
# Desenvolvimento: deixe vazio — usa LocMemCache automaticamente
# Produção: use Redis para melhor performance e persistência entre workers
# CACHE_URL=redis://localhost:6379/1

# ──────────────────────────────────────────────────────────────────────────────
# E-mail — Formulário de Contato (Gmail SMTP com App Password)
# ──────────────────────────────────────────────────────────────────────────────
# PASSO A PASSO para Gmail:
#   1. Ative a verificação em 2 etapas na sua conta Google
#   2. Acesse: https://myaccount.google.com/apppasswords
#   3. Crie um App Password para "MyNutri AI"
#   4. Cole a senha de 16 dígitos gerada em EMAIL_HOST_PASSWORD (sem espaços)
#
# Desenvolvimento: deixe vazio — o backend imprime o e-mail no console automaticamente.
# Produção: preencha USER e PASSWORD no painel de variáveis do Render.

# Backend de e-mail (opcional — padrão automático: console em dev, SMTP em prod)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# Protocolo de segurança — escolha um:
#   TLS (porta 587, padrão): EMAIL_USE_SSL=False  ← padrão, não precisa definir
#   SSL (porta 465):         EMAIL_USE_SSL=True + EMAIL_PORT=465
# Atenção: EMAIL_USE_TLS é derivado automaticamente (= NOT EMAIL_USE_SSL)
# e NÃO deve ser definido no .env.
# EMAIL_USE_SSL=False
EMAIL_HOST_USER=mynutriai.app@gmail.com
EMAIL_HOST_PASSWORD=sua-app-password-de-16-digitos-aqui

# Endereço que receberá as mensagens do formulário de contato
CONTACT_EMAIL=mynutriai.app@gmail.com

# ──────────────────────────────────────────────────────────────────────────────
# Validação de E-mail (opcional — desativado por padrão)
# ──────────────────────────────────────────────────────────────────────────────
# Timeout DNS em segundos (padrão: 5)
# EMAIL_DNS_TIMEOUT=5

# Verificação SMTP — mais precisa, porém mais lenta (padrão: False)
# EMAIL_SMTP_ENABLED=False
# EMAIL_SMTP_TIMEOUT=10

# Validação via API externa — requer chave (padrão: False)
# EMAIL_VALIDATION_USE_API=False
# EMAIL_VALIDATION_PROVIDER=zerobounce   # zerobounce ou hunter
# EMAIL_VALIDATION_API_KEY=sua-chave-aqui
# EMAIL_VALIDATION_CACHE_TTL=86400       # cache de resultados em segundos (24h)

# ──────────────────────────────────────────────────────────────────────────────
# Celery — Geração Assíncrona de Dietas
# ──────────────────────────────────────────────────────────────────────────────
# Desenvolvimento: deixe vazio — tasks rodam de forma síncrona automaticamente
#                  (sem necessidade de worker ou Redis)
#
# Produção: configure Redis como broker
#   Render: adicione um Redis add-on e copie a URL gerada
#   Formato: redis://:senha@host:6379/0
#
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
#
# Worker em produção (adicione ao render.yaml como segundo serviço):
#   startCommand: celery -A mynutri worker --loglevel=info --concurrency=2

# ──────────────────────────────────────────────────────────────────────────────
# Logging (opcional)
# ──────────────────────────────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR
# Padrão: INFO em dev, WARNING em prod
LOG_LEVEL=INFO
